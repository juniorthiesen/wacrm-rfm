# ============================================================
# wacrm production env — copy to .env.production on the VPS.
#
# Generate the secrets:
#   bash scripts/deploy/generate-secrets.sh
# ============================================================

# ---------- Supabase (self-hosted on the same VPS) ----------
# When the app runs inside Docker, it must talk to Kong by its
# service name — NOT by the public domain (TLS isn't terminated
# internally). The browser, on the other hand, uses the public
# URL since NEXT_PUBLIC_* is inlined into the client bundle.
#
# Run two values for that reason:
#   NEXT_PUBLIC_SUPABASE_URL  — public, baked into JS (browser hits this)
#   SUPABASE_INTERNAL_URL     — internal, used by server code (optional override)
#
# For simplicity we just point both at the public URL here and let
# the request route via Cloudflare → CloudPanel → Kong. If you
# notice round-trip overhead on server-side calls, set
# NEXT_PUBLIC_SUPABASE_URL=https://sb.auroralabs.com.br for
# the browser and override the server client to use http://kong:8000.

NEXT_PUBLIC_SUPABASE_URL=https://sb.auroralabs.com.br
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-jwt-from-supabase-.env

# Service-role key (bypasses RLS). Stays server-side only.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-jwt-from-supabase-.env

# Postgres password — must match POSTGRES_PASSWORD in supabase/docker/.env.
# Used by the migrate one-shot container to apply schema migrations.
POSTGRES_PASSWORD=replace-with-strong-password

# ---------- WaCRM ----------
# Public canonical URL of this deployment.
NEXT_PUBLIC_SITE_URL=https://crm.auroralabs.com.br

# AES-256-GCM key for stored WhatsApp tokens (64 hex chars = 32 bytes).
# Rotating this orphans every encrypted token.
ENCRYPTION_KEY=replace-with-64-hex-chars

# Meta App Secret (Meta for Developers → App Settings → Basic).
META_APP_SECRET=replace-with-meta-app-secret

# Shared secret protecting GET /api/automations/cron.
# Required because the automation-cron container in docker-compose.yml
# uses it to drain Wait steps every minute.
AUTOMATION_CRON_SECRET=replace-with-long-random-string

# ---------- Compose overrides (optional) ----------
# Port the app binds on the host (always 127.0.0.1). CloudPanel's
# reverse proxy site should target http://127.0.0.1:<APP_PORT>.
# We use 3000 to match the default CloudPanel reverse-proxy setup;
# the Supabase Studio container is moved to port 3001 to avoid the
# collision (see docs/deploy-vps.md).
APP_PORT=3000

# External docker network created by the Supabase compose. Default
# is "supabase_default"; override if you renamed the project.
# SUPABASE_NETWORK=supabase_default
